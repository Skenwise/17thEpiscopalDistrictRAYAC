rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Check if user is admin (you can expand this later)
    function isAdmin() {
      return isAuthenticated();
    }
    
    // ============================================
    // PUBLIC COLLECTIONS (read only for visitors)
    // ============================================
    
    match /events/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /trainings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /gallery_images/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /resources/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /store_items/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /prayer_requests/{document} {
      allow read: if true;
      allow write: if true;  // Anyone can submit prayer requests
    }
    
    // ============================================
    // MEMBER DATA (authenticated users only)
    // ============================================
    
    match /members/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================
    // ENROLLMENTS & RSVPS (CRITICAL FIX HERE)
    // ============================================
    
    match /training_enrollments/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAuthenticated();  // Members can enroll themselves
    }
    
    match /event_rsvps/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAuthenticated();  // Members can RSVP
    }
    
    match /volunteer_applications/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAuthenticated();
    }
    
    // ============================================
    // OTHER COLLECTIONS
    // ============================================
    
    match /donations/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAuthenticated();
    }
    
    match /forum_posts/{document} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /forum_comments/{document} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // ============================================
    // FALLBACK (secure by default)
    // ============================================
    
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}