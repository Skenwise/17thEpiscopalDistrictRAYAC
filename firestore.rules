rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'pgilbertmwanza@gmail.com' ||
        request.auth.token.email == 'sage.kona.dev@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /rsvps/{rsvpId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /training_enrollments/{enrollmentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /volunteer_applications/{applicationId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /prayer_requests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /forum_threads/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
      allow read: if isAdmin();
    }

    match /pendingUnlocks/{email} {
      allow read, write: if false;
    }

    // ===== ADDED COLLECTIONS =====
    
    match /trainings/{trainingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /volunteer_opportunities/{oppId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /store_products/{productId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
