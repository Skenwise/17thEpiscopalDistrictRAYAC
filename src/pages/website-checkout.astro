---
// This is a static Astro page that will render the React component
// The React component will handle its own routing via URL parameters
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout | RAYAC</title>
  </head>
  <body>
    <div id="root"></div>
    <script type="module">
      import { createRoot } from 'react-dom/client';
      import WebsiteCheckoutPage from '/src/components/pages/WebsiteCheckoutPage';
      
      const root = createRoot(document.getElementById('root'));
      root.render(WebsiteCheckoutPage());
    </script>
  </body>
</html>
