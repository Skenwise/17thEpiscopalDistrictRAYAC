rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /resources/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.email == 'pgilbertmwanza@gmail.com' ||
        request.auth.token.email == 'sage.kona.dev@gmail.com'
      );
    }
  }
}
